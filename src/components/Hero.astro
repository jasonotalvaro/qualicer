---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const agendaHref   = lang === 'en' ? '/en/agenda' : '/agenda';
const entradasHref = 'https://tickets.qualicer2026.com';

/* Split \n into array for multiline rendering */
function lines(str: string) {
  return str.split('\n');
}
---

<section class="hero">
  <!-- Video background – muted + playsinline son obligatorios para Safari/iOS -->
  <video class="hero-video hero-video--desktop" autoplay muted loop playsinline preload="metadata" aria-hidden="true">
    <source src="/videos/desktop.mp4" type="video/mp4" />
  </video>
  <video class="hero-video hero-video--mobile" autoplay muted loop playsinline preload="metadata" aria-hidden="true">
    <source src="/videos/Mobile.mp4" type="video/mp4" />
  </video>

  <!-- Content overlay -->
  <div class="hero-inner">

    <!-- LEFT: card de contenido -->
    <div class="hero-card">

      <!-- Bloque superior: textos -->
      <div class="hero-card-top">
        <p class="hero-congress">{t('hero.congress' as any)}</p>

        <h1 class="hero-headline" aria-label={`${t('hero.headline1' as any)} ${t('hero.headline2' as any)}`}>
          <span>{t('hero.headline1' as any)}</span>
          <span>{t('hero.headline2' as any)}</span>
        </h1>

        <p class="hero-desc">
          {lines(t('hero.desc' as any)).map((l, i, arr) => (
            <>{l}{i < arr.length - 1 && <br />}</>
          ))}
        </p>
      </div>

      <!-- Bloque inferior: info evento + organizadores -->
      <div class="hero-card-bottom">

        <div class="hero-event">
          <div class="hero-event-row">
            <span class="hero-date">
              {lines(t('hero.date' as any)).map((l, i, arr) => (
                <>{l}{i < arr.length - 1 && <br />}</>
              ))}
            </span>
            <div class="hero-venue">
              <span>
                {lines(t('hero.venue' as any)).map((l, i, arr) => (
                  <>{l}{i < arr.length - 1 && <br />}</>
                ))}
              </span>
              <span>
                {lines(t('hero.city' as any)).map((l, i, arr) => (
                  <>{l}{i < arr.length - 1 && <br />}</>
                ))}
              </span>
            </div>
          </div>
        </div>

        <div class="hero-organizers">
          <p class="hero-org-label">{t('hero.organizers' as any)}</p>
          <div class="hero-org-logos">
            <a href="https://iicv.net/" target="_blank" rel="noopener">
              <img src="/img/cole.svg" alt="Colegio de Ingenieros Industriales" />
            </a>
            <a href="https://www.laboratoriocarpi.com/" target="_blank" rel="noopener">
              <img src="/img/sebas.svg" alt="Laboratorio Sebastián Carpi" />
            </a>
          </div>
        </div>

      </div>
    </div>

    <!-- RIGHT: CTAs (alineados al fondo por align-items: flex-end del padre) -->
    <div class="hero-ctas">
      <a href={agendaHref} class="btn-secondary">{t('hero.program' as any)}</a>
      <a href={entradasHref} target="_blank" rel="noopener" class="btn-primary">{t('hero.tickets' as any)}</a>
    </div>

  </div>

  <!-- Flecha scroll: bottom center, fuera del inner para no afectar al layout -->
  <a href="#datos" class="hero-scroll-arrow" aria-label="Ir al siguiente bloque">
    <svg width="34" height="34" viewBox="0 0 34 34" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M9.48066 19.3973L10.4996 18.3947L16.2916 24.1867L16.2916 7.08331L17.7083 7.08331L17.7083 24.1867L23.5003 18.3947L24.5193 19.3973L17 26.9166L9.48066 19.3973Z" fill="#262624"/>
    </svg>
  </a>
</section>

<style>
  /* ── Section ─────────────────────────────────────────── */
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
  }

  /* ── Video background ────────────────────────────────── */
  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .hero-video--mobile { display: none; }

  /* ── Content overlay ─────────────────────────────────── */
  .hero-inner {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding: 2.4rem;               /* 48px */
  }

  /* ── Left card ───────────────────────────────────────── */
  .hero-card {
    width: 32.3rem;                /* 646px */
    height: 38.15rem;              /* 763px */
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    border-radius: var(--radius-card);
  }

  .hero-card-top {
    display: flex;
    flex-direction: column;
    gap: 2.4rem;                   /* 48px */
  }

  .hero-congress {
    font-size: 1.5rem;             /* 30px */
    font-weight: 600;
    line-height: 1.1em;
    max-width: 25.8rem;            /* 516px */
    color: var(--color-dark);
  }

  .hero-headline {
    display: flex;
    flex-direction: column;
    font-size: 6.5rem;             /* 130px */
    font-weight: 600;
    line-height: 1em;
    letter-spacing: -0.04em;
    color: var(--color-dark);
  }

  .hero-desc {
    font-size: 0.8rem;             /* 16px */
    font-weight: 400;
    line-height: 1.4em;
    color: var(--color-dark);
  }

  /* ── Bottom card ─────────────────────────────────────── */
  .hero-card-bottom {
    display: flex;
    flex-direction: column;
    gap: 3.2rem;                   /* 64px */
  }

  .hero-event {
    width: 23.3rem;                /* 466px */
  }

  .hero-event-row {
    display: flex;
    gap: 6.35rem;                  /* 127px */
    align-items: flex-start;
  }

  .hero-date,
  .hero-venue span {
    font-size: 0.8rem;             /* 16px */
    font-weight: 400;
    line-height: 1.4em;
    color: var(--color-dark);
  }

  .hero-venue {
    display: flex;
    gap: 1.4rem;                   /* 28px */
  }

  .hero-organizers {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;                   /* 12px */
    width: 23.3rem;                /* 466px */
  }

  .hero-org-label {
    font-size: 0.6rem;             /* 12px */
    font-weight: 400;
    line-height: 1.4em;
    color: var(--color-dark);
  }

  .hero-org-logos {
    display:     flex;
    align-items: flex-end;
    gap:         2.4rem;           /* 48px */
  }

  .hero-org-logos a {
    display:     flex;
    align-items: flex-end;
  }

  .hero-org-logos img {
    display: block;
    height:  auto;
    width:   auto;
  }

  /* ── Scroll arrow ───────────────────────────────────── */
  .hero-scroll-arrow {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
  }

  /* ── Right CTAs ──────────────────────────────────────── */
  .hero-ctas {
    display: flex;
    align-items: center;
    gap: 0.4rem;                   /* 8px */
  }

  /* ── Mobile ──────────────────────────────────────────── */
  @media (max-width: 767px) {
    .hero {
      height: 100svh;
    }

    .hero-video--desktop { display: none; }
    .hero-video--mobile  { display: block; }

    .hero-scroll-arrow {
      display: none;
    }

    .hero-inner {
      position: absolute;
      inset: 0;
      flex-direction: column;
      justify-content: space-between !important;
      gap: 32px;
      padding: 24px 20px;
    }

    .hero-card {
      width: 100%;
      height: auto;
      flex: 1;
      margin-top: 60px;
      border-radius: 30px;
      justify-content: space-between;
    }

    .hero-card-top {
      gap: 20px;
    }

    .hero-congress {
      font-size: 16px;
      max-width: 100%;
    }

    .hero-headline {
      font-size: 44px;
      line-height: 1;
      letter-spacing: -0.03em;
      flex-direction: row;
      gap: 0.25em;
    }

    .hero-desc {
      font-size: 14px;
    }

    .hero-event {
      width: 100% !important;
    }

    .hero-event-row {
      flex-direction: row !important;
      gap: 20px;
    }

    .hero-venue {
      gap: 20px;
    }

    .hero-date,
    .hero-venue span {
      font-size: 14px;
    }

    .hero-card-bottom {
      margin-top: 20px;
      flex: 1;
      justify-content: space-between;
      gap: 24px;
    }

    .hero-organizers {
      display: flex;
      width: 100%;
    }

    .hero-org-label {
      font-size: 12px;
    }

    .hero-org-logos { gap: 48px; }
    .hero-org-logos a:first-child img { width: 130px; }
    .hero-org-logos a:last-child  img { width: 111px; }

    .hero-ctas {
      width: 100%;
      flex-direction: row;
      align-items: stretch;
      gap: 8px;
    }

    .hero-ctas .btn-secondary,
    .hero-ctas .btn-primary {
      flex: 1;
      justify-content: center;
      font-size: 16px;
      font-weight: 500;
      line-height: 1;
      padding: 14px 22px;
    }
  }
</style>
