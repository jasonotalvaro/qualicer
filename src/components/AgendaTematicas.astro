---
import { client } from '../lib/sanity';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t    = useTranslations(lang);

const agendaHref = lang === 'en' ? '/en/agenda' : '/agenda';

const rawTitulos: { titulo: { es?: string; en?: string } }[] = await client.fetch(
  `*[_type == "agenda" && defined(titulo)] { titulo }`
);

const allTitles = rawTitulos.map(s =>
  lang === 'en' ? (s.titulo?.en ?? s.titulo?.es ?? '') : (s.titulo?.es ?? s.titulo?.en ?? '')
).filter(Boolean);
---

<section class="b7">
  <div class="b7-inner">

    <h2 class="b7-title">{t('b7.title')}</h2>

    <div class="b7-topics" id="b7-topics" data-titles={JSON.stringify(allTitles)}>
      <div class="b7-col" id="b7-col1"></div>
      <div class="b7-col" id="b7-col2"></div>
    </div>

    <a href={agendaHref} class="b7-btn">{t('b7.cta')}</a>

  </div>
</section>

<script>
  (() => {
    const container = document.getElementById('b7-topics');
    if (!container) return;
    const titles: string[] = JSON.parse(container.dataset.titles || '[]');
    for (let i = titles.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [titles[i], titles[j]] = [titles[j], titles[i]];
    }
    const picked = titles.slice(0, 6);
    const col1 = document.getElementById('b7-col1');
    const col2 = document.getElementById('b7-col2');
    picked.slice(0, 3).forEach(text => {
      const p = document.createElement('p');
      p.className = 'b7-topic';
      p.textContent = text;
      col1?.appendChild(p);
    });
    picked.slice(3, 6).forEach(text => {
      const p = document.createElement('p');
      p.className = 'b7-topic';
      p.textContent = text;
      col2?.appendChild(p);
    });
  })();
</script>

<style>
  /* Sección: blanco full-width sobre fondo gris */
  .b7 {
    background:  #FEFEFE;
    margin-top:  9.8rem;   /* 196px / 20px — mismo gap que otros bloques */
  }

  /* Contenedor interior: mismo padding lateral que B6 (2.4rem) */
  .b7-inner {
    max-width:       1920px;
    margin:          0 auto;
    padding:         1.6rem 2.4rem;  /* 32px vertical (Figma), 2.4rem lateral */
    display:         flex;
    flex-direction:  column;
    justify-content: space-between;
    min-height:      39.15rem;       /* 783px / 20px — altura del card en Figma */
    position:        relative;
  }

  /* Título: 514px exactos del diseño */
  .b7-title {
    width:          25.7rem;   /* 514px / 20px */
    font-size:      2.4rem;    /* 48px */
    font-weight:    600;
    line-height:    1.1em;
    letter-spacing: -0.02em;
    color:          var(--color-dark);
  }

  /* Grid de temas: 2 columnas fijas de 613 px, el resto queda vacío */
  .b7-topics {
    display: flex;
    gap:     3.2rem;   /* 64px */
  }

  .b7-col {
    width:          30.65rem;  /* 613px — fijo como en Figma */
    flex-shrink:    0;
    display:        flex;
    flex-direction: column;
    gap:            2.4rem;    /* 48px */
  }

  :global(.b7-topic) {
    font-size:   1.5rem;   /* 30px */
    font-weight: 600;
    line-height: 1.1em;
    color:       #989898;
  }

  /* Botón secundario — mismo estilo que B6 */
  .b7-btn {
    position:        absolute;
    bottom:          1.6rem;
    right:           2.4rem;
    display:         inline-flex;
    justify-content: center;
    align-items:     center;
    padding:         0.7rem 1.1rem 0.8rem;
    border:          1px solid var(--color-dark);
    border-radius:   100px;
    background:      transparent;
    font-family:     inherit;
    font-size:       1rem;
    font-weight:     500;
    line-height:     1;
    color:           var(--color-dark);
    text-decoration: none;
    white-space:     nowrap;
  }

  /* ─── Mobile ────────────────────────────────────────────── */
  @media (max-width: 767px) {
    .b7 {
      margin-top: 196px;
    }

    .b7-inner {
      padding:       24px;
      min-height:    600px;
      margin-bottom: auto;
      position:      static;
    }

    .b7-title {
      width:          300px;
      max-width:      none;
      font-size:      40px;
      font-style:     normal;
      font-weight:    600;
      line-height:    100%;
      letter-spacing: -0.8px;
      margin-bottom:  auto;
    }

    /* Columna única: las dos cols del desktop se apilan */
    .b7-topics {
      flex-direction: column;
      gap:            0;
    }

    .b7-col {
      width:       auto;
      flex-shrink: unset;
      gap:         20px;
    }

    /* Separación visual entre los dos grupos originales */
    .b7-col + .b7-col {
      margin-top: 0;
    }

    :global(.b7-topic) { font-size: 21px; }

    /* Botón: flujo normal, ancho completo */
    .b7-btn {
      position:        static;
      display:         flex;
      width:           100%;
      box-sizing:      border-box;
      margin-top:      32px;
      font-size:       20px;
      padding:         16px 24px;
      justify-content: center;
    }

    .b7-col:first-child { display: none; }
  }
</style>
