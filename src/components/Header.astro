---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface Props {
  activePage?: string;
}
const { activePage = 'home' } = Astro.props;

const navLinks = [
  { key: 'nav.home',      href: lang === 'en' ? '/en/' : '/',             id: 'home'      },
  { key: 'nav.speakers',  href: lang === 'en' ? '/en/ponentes/' : '/ponentes/', id: 'speakers'  },
  { key: 'nav.agenda',    href: lang === 'en' ? '/en/agenda/'   : '/agenda/',   id: 'agenda'    },
  { key: 'nav.manifesto', href: lang === 'en' ? '/en/manifesto/': '/manifesto/',id: 'manifesto' },
  { key: 'nav.contact',   href: lang === 'en' ? '/en/contacto/' : '/contacto/', id: 'contact'   },
] as const;
---

<header class="header">
  <!-- Logo -->
  <a href={lang === 'en' ? '/en/' : '/'} class="header-logo" aria-label="Qualicer">
    <img src="/img/logo.svg" alt="Qualicer" width="182" height="29" />
  </a>

  <!-- Nav group (desktop) -->
  <nav class="header-nav" aria-label="Navegación principal">

    <!-- Links + botón Entradas (gap 32px, igual que Figma Frame 43) -->
    <div class="header-nav-links">
      {navLinks.map(({ key, href, id }) => (
        <a href={href} class:list={['btn-nav', { active: activePage === id }]}>
          {t(key as any)}
        </a>
      ))}
      <a href={lang === 'en' ? '/en/entradas' : '/entradas'} class="btn-primary">
        {t('nav.tickets' as any)}
      </a>
    </div>

    <!-- Selector de idioma (gap 48px desde el grupo, igual que Figma Frame 796) -->
    <details class="lang-switcher">
      <summary class="btn-dropdown" aria-label="Cambiar idioma">
        {lang === 'en' ? 'EN' : 'ES'}
        <svg class="lang-arrow" width="10" height="12" viewBox="0 0 10 12" fill="none" aria-hidden="true">
          <path d="M5 12L0.669872 4.5L9.33013 4.5L5 12Z" fill="currentColor"/>
        </svg>
      </summary>
      <div class="lang-menu">
        <a href={lang === 'en' ? '/' : '/en/'} class="lang-option">
          {lang === 'en' ? 'ES' : 'EN'}
        </a>
      </div>
    </details>

  </nav>

  <!-- Hamburger (mobile only) -->
  <button class="menu-toggle" aria-label="Abrir menú" aria-expanded="false" aria-controls="mobile-menu">
    <svg width="24" height="16" viewBox="0 0 24 16" fill="none" aria-hidden="true">
      <rect width="24" height="2" rx="1" fill="currentColor"/>
      <rect y="7" width="24" height="2" rx="1" fill="currentColor"/>
      <rect y="14" width="24" height="2" rx="1" fill="currentColor"/>
    </svg>
  </button>
</header>

<!-- Mobile menu panel -->
<div class="mobile-menu" id="mobile-menu" aria-hidden="true">
  <div class="mobile-menu-top">
    <a href={lang === 'en' ? '/en/' : '/'} class="mobile-menu-logo" aria-label="Qualicer">
      <img src="/img/logo.svg" alt="Qualicer" width="135" height="21" />
    </a>
    <button class="mobile-menu-close" aria-label="Cerrar menú">
      <img src="/img/close.svg" alt="" aria-hidden="true" width="24" height="24" />
    </button>
  </div>

  <nav class="mobile-menu-nav" aria-label="Navegación mobile">
    {navLinks.map(({ key, href, id }) => (
      <a href={href} class:list={['mobile-nav-link', { active: activePage === id }]}>
        {t(key as any)}
      </a>
    ))}
    <a href={lang === 'en' ? '/' : '/en/'} class="mobile-nav-link mobile-nav-lang">
      {lang === 'en' ? 'ES' : 'EN'}
    </a>
  </nav>
</div>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const closeBtn = menu?.querySelector<HTMLButtonElement>('.mobile-menu-close');

  function openMenu() {
    menu?.classList.add('is-open');
    toggle?.setAttribute('aria-expanded', 'true');
    menu?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu?.classList.remove('is-open');
    toggle?.setAttribute('aria-expanded', 'false');
    menu?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  menu?.querySelectorAll('a').forEach(link => link.addEventListener('click', closeMenu));

  // Hide on scroll down, show on scroll up
  const header = document.querySelector<HTMLElement>('.header');
  let lastY = window.scrollY;

  window.addEventListener('scroll', () => {
    const currentY = window.scrollY;
    if (currentY > lastY && currentY > 80) {
      header?.classList.add('header--hidden');
    } else {
      header?.classList.remove('header--hidden');
    }
    lastY = currentY;
  }, { passive: true });
</script>

<style>
  .header {
    position: fixed;
    top: 0;
    z-index: 100;
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.8rem 2.4rem;   /* 16px 48px */
    background: rgba(255, 255, 255, 0.75);
    backdrop-filter: blur(8.5px);
    -webkit-backdrop-filter: blur(8.5px);
    border-bottom: 1px solid var(--color-dark);
    transition: transform 0.3s ease;
  }

  .header--hidden {
    transform: translateY(-100%);
  }

  .header-logo img {
    width: 9.1rem;
    height: auto;
  }

  /* Grupo derecho: [links+botón] | [lang] — gap 48px */
  .header-nav {
    display: flex;
    align-items: center;
    gap: 2.4rem;   /* 48px */
  }

  /* Links + botón Entradas — gap 32px */
  .header-nav-links {
    display: flex;
    align-items: center;
    gap: 1.6rem;   /* 32px */
  }

  /* Nav links: sin borde, activo con underline inferior */
  .btn-nav {
    font-family:           var(--font);
    font-size:             1rem;
    font-weight:           500;
    line-height:           1.4em;
    color:                 var(--color-dark);
    background:            transparent;
    border:                none;
    padding:               0;
    white-space:           nowrap;
    cursor:                pointer;
    text-decoration:       none;
    text-underline-offset: 3px;
    transition:            opacity 0.15s ease;
  }

  .btn-nav.active {
    text-decoration: underline;
  }

  .btn-nav:hover { opacity: 0.7; }

  /* Botón Entradas */
  .btn-primary {
    font-family:     var(--font);
    font-size:       1rem;     /* 20px */
    font-weight:     500;
    line-height:     1;
    display:         inline-flex;
    align-items:     center;
    justify-content: center;
    padding:         0.7rem 1.1rem 0.8rem;  /* 14px 22px 16px */
    background:      var(--color-primary);
    color:           var(--color-white);
    border:          none;
    border-radius:   var(--radius-pill);
    white-space:     nowrap;
    cursor:          pointer;
    text-decoration: none;
    transition:      opacity 0.15s ease;
  }

  .btn-primary:hover { opacity: 0.85; }

  /* Language switcher */
  .lang-switcher {
    position: relative;
  }

  .lang-switcher summary {
    list-style: none;
  }

  .lang-switcher summary::-webkit-details-marker {
    display: none;
  }

  .btn-dropdown {
    font-family:  var(--font);
    font-size:    1rem;
    font-weight:  500;
    line-height:  1.4em;
    color:        var(--color-dark);
    background:   transparent;
    border:       none;
    padding:      0.3rem 0;
    display:      inline-flex;
    align-items:  center;
    gap:          0.3rem;   /* 6px */
    white-space:  nowrap;
    cursor:       pointer;
    transition:   opacity 0.15s ease;
  }

  .btn-dropdown:hover { opacity: 0.7; }

  .lang-menu {
    position:    absolute;
    top:         calc(100% + 0.3rem);
    left:        0;
    min-width:   100%;
    display:     flex;
    flex-direction: column;
    background:  rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8.5px);
    -webkit-backdrop-filter: blur(8.5px);
    border:      1px solid var(--color-dark);
    border-radius: 8px;
    overflow:    hidden;
    z-index:     10;
  }

  .lang-option {
    font-family:     var(--font);
    font-size:       1rem;
    font-weight:     500;
    line-height:     1.4em;
    padding:         0.5rem 0.8rem;
    color:           var(--color-dark);
    text-align:      center;
    white-space:     nowrap;
    text-decoration: none;
    transition:      opacity 0.15s ease;
  }

  .lang-option:hover { opacity: 0.7; }

  .lang-arrow {
    transition: transform 0.2s ease;
  }

  details[open] .lang-arrow {
    transform: rotate(180deg);
  }

  /* ── Hamburger (hidden on desktop) ── */
  .menu-toggle {
    display: none;
  }

  /* ── Mobile menu panel (hidden by default) ── */
  .mobile-menu {
    display: none;
  }

  /* ── Mobile ── */
  @media (max-width: 767px) {
    .header {
      padding: 18px 24px;
    }

    .header-logo img {
      width: 135px;
    }

    .header-nav {
      display: none;
    }

    .menu-toggle {
      display: flex;
      align-items: center;
      justify-content: center;
      background: none;
      border: none;
      color: var(--color-dark);
      cursor: pointer;
      padding: 4px;
    }

    /* ── Mobile menu panel ── */
    .mobile-menu {
      display: block;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 200;
      background: var(--color-white);
      padding: 18px 24px 32px;
      transform: translateX(100%);
      transition: transform 0.28s ease;
    }

    .mobile-menu.is-open {
      transform: translateX(0);
    }

    .mobile-menu-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 32px;
    }

    .mobile-menu-logo img {
      width: 135px;
      height: auto;
    }

    .mobile-menu-close {
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .mobile-menu-nav {
      display: flex;
      flex-direction: column;
    }

    .mobile-nav-link {
      font-family: var(--font);
      font-size: 16px;
      font-weight: 500;
      line-height: 1.4;
      color: var(--color-dark);
      padding: 14px 0;
      display: block;
    }

    .mobile-nav-link.active {
      font-weight: 600;
    }

    .mobile-nav-lang {
      margin-top: 8px;
      opacity: 0.6;
    }
  }
</style>
