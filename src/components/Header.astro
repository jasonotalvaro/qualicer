---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface Props {
  activePage?: string;
}
const { activePage = 'home' } = Astro.props;

const navLinks = [
  { key: 'nav.home',      href: lang === 'en' ? '/en/' : '/',             id: 'home'      },
  { key: 'nav.speakers',  href: lang === 'en' ? '/en/ponentes/' : '/ponentes/', id: 'speakers'  },
  { key: 'nav.agenda',    href: lang === 'en' ? '/en/agenda/'   : '/agenda/',   id: 'agenda'    },
  { key: 'nav.manifesto', href: lang === 'en' ? '/en/manifesto/': '/manifesto/',id: 'manifesto' },
  { key: 'nav.contact',   href: lang === 'en' ? '/en/contacto/' : '/contacto/', id: 'contact'   },
] as const;
---

<header class="header">
  <!-- Logo -->
  <a href={lang === 'en' ? '/en/' : '/'} class="header-logo" aria-label="Qualicer">
    <img src="/img/logo.svg" alt="Qualicer" width="182" height="29" />
  </a>

  <!-- Nav group (desktop) -->
  <nav class="header-nav" aria-label="Navegación principal">
    <div class="header-nav-links">
      {navLinks.map(({ key, href, id }) => (
        <a href={href} class:list={['btn-nav', { active: activePage === id }]}>
          {t(key as any)}
        </a>
      ))}
    </div>

    <!-- Language switcher -->
    <details class="lang-switcher">
      <summary class="btn-dropdown" aria-label="Cambiar idioma">
        {lang === 'en' ? 'EN' : 'ES'}
        <svg class="lang-arrow" width="8" height="10" viewBox="0 0 8 10" fill="none" aria-hidden="true">
          <path d="M4 10L0.535898 4L7.4641 4L4 10Z" fill="currentColor"/>
        </svg>
      </summary>
      <div class="lang-menu">
        <a href={lang === 'en' ? '/' : '/en/'} class="lang-option">
          {lang === 'en' ? 'ES' : 'EN'}
        </a>
      </div>
    </details>

    <!-- CTA -->
    <a href="#entradas" class="btn-primary">{t('nav.tickets' as any)}</a>
  </nav>

  <!-- Hamburger (mobile only) -->
  <button class="menu-toggle" aria-label="Abrir menú" aria-expanded="false" aria-controls="mobile-menu">
    <svg width="24" height="16" viewBox="0 0 24 16" fill="none" aria-hidden="true">
      <rect width="24" height="2" rx="1" fill="currentColor"/>
      <rect y="7" width="24" height="2" rx="1" fill="currentColor"/>
      <rect y="14" width="24" height="2" rx="1" fill="currentColor"/>
    </svg>
  </button>
</header>

<!-- Mobile menu panel -->
<div class="mobile-menu" id="mobile-menu" aria-hidden="true">
  <div class="mobile-menu-top">
    <a href={lang === 'en' ? '/en/' : '/'} class="mobile-menu-logo" aria-label="Qualicer">
      <img src="/img/logo.svg" alt="Qualicer" width="135" height="21" />
    </a>
    <button class="mobile-menu-close" aria-label="Cerrar menú">
      <img src="/img/close.svg" alt="" aria-hidden="true" width="24" height="24" />
    </button>
  </div>

  <nav class="mobile-menu-nav" aria-label="Navegación mobile">
    {navLinks.map(({ key, href, id }) => (
      <a href={href} class:list={['mobile-nav-link', { active: activePage === id }]}>
        {t(key as any)}
      </a>
    ))}
    <a href={lang === 'en' ? '/' : '/en/'} class="mobile-nav-link mobile-nav-lang">
      {lang === 'en' ? 'ES' : 'EN'}
    </a>
  </nav>
</div>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const closeBtn = menu?.querySelector<HTMLButtonElement>('.mobile-menu-close');

  function openMenu() {
    menu?.classList.add('is-open');
    toggle?.setAttribute('aria-expanded', 'true');
    menu?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu?.classList.remove('is-open');
    toggle?.setAttribute('aria-expanded', 'false');
    menu?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  menu?.querySelectorAll('a').forEach(link => link.addEventListener('click', closeMenu));
</script>

<style>
  .header {
    position: fixed;
    top: 0;
    z-index: 100;
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 2.4rem;
    background: var(--color-glass);
    backdrop-filter: blur(8.5px);
    -webkit-backdrop-filter: blur(8.5px);
    border-bottom: 1px solid var(--color-dark);
  }

  .header-logo img {
    width: 9.1rem;
    height: auto;
  }

  .header-nav {
    display: flex;
    align-items: center;
    gap: 1.6rem;
  }

  .header-nav-links {
    display: flex;
    align-items: center;
    gap: 0.2rem;
  }

  .btn-nav, .btn-dropdown, .btn-primary {
    font-family: var(--font);
    font-size: 0.8rem;
    font-weight: 500;
    line-height: 1.2;
    padding: 0.6rem 0.9rem;
    border-radius: var(--radius-pill);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    white-space: nowrap;
    cursor: pointer;
    transition: opacity 0.15s ease;
  }

  .btn-nav {
    background: transparent;
    color: var(--color-dark);
    border: 1px solid var(--color-dark);
  }

  .btn-nav.active {
    border-width: 2px;
    font-weight: 600;
  }

  .btn-dropdown {
    background: transparent;
    color: var(--color-dark);
    border: 1px solid var(--color-dark);
    gap: 0.3rem;
  }

  .btn-primary {
    background: var(--color-primary);
    color: var(--color-white);
    border: none;
  }

  .btn-nav:hover, .btn-dropdown:hover, .btn-primary:hover {
    opacity: 0.8;
  }

  /* ── Language switcher ── */
  .lang-switcher {
    position: relative;
  }

  .lang-switcher summary {
    list-style: none;
  }

  .lang-switcher summary::-webkit-details-marker {
    display: none;
  }

  .lang-menu {
    position: absolute;
    top: calc(100% + 0.3rem);
    left: 0;
    min-width: 100%;
    display: flex;
    flex-direction: column;
    background: var(--color-glass);
    backdrop-filter: blur(8.5px);
    -webkit-backdrop-filter: blur(8.5px);
    border: 1px solid var(--color-dark);
    border-radius: var(--radius-pill);
    overflow: hidden;
    z-index: 10;
  }

  .lang-option {
    font-family: var(--font);
    font-size: 0.8rem;
    font-weight: 500;
    line-height: 1.2;
    padding: 0.6rem 0.9rem;
    color: var(--color-dark);
    text-align: center;
    white-space: nowrap;
    transition: opacity 0.15s ease;
  }

  .lang-option:hover {
    opacity: 0.8;
  }

  .lang-arrow {
    transition: transform 0.2s ease;
  }

  details[open] .lang-arrow {
    transform: rotate(180deg);
  }

  /* ── Hamburger (hidden on desktop) ── */
  .menu-toggle {
    display: none;
  }

  /* ── Mobile menu panel (hidden by default) ── */
  .mobile-menu {
    display: none;
  }

  /* ── Mobile ── */
  @media (max-width: 767px) {
    .header {
      padding: 18px 24px;
    }

    .header-logo img {
      width: 135px;
    }

    .header-nav {
      display: none;
    }

    .menu-toggle {
      display: flex;
      align-items: center;
      justify-content: center;
      background: none;
      border: none;
      color: var(--color-dark);
      cursor: pointer;
      padding: 4px;
    }

    /* ── Mobile menu panel ── */
    .mobile-menu {
      display: block;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 200;
      background: var(--color-white);
      padding: 18px 24px 32px;
      transform: translateX(100%);
      transition: transform 0.28s ease;
    }

    .mobile-menu.is-open {
      transform: translateX(0);
    }

    .mobile-menu-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 32px;
    }

    .mobile-menu-logo img {
      width: 135px;
      height: auto;
    }

    .mobile-menu-close {
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .mobile-menu-nav {
      display: flex;
      flex-direction: column;
    }

    .mobile-nav-link {
      font-family: var(--font);
      font-size: 16px;
      font-weight: 500;
      line-height: 1.4;
      color: var(--color-dark);
      padding: 14px 0;
      display: block;
    }

    .mobile-nav-link.active {
      font-weight: 600;
    }

    .mobile-nav-lang {
      margin-top: 8px;
      opacity: 0.6;
    }
  }
</style>
