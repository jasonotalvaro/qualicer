---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface Props {
  activePage?: string;
  darkBg?: boolean;
}
const { activePage = 'home', darkBg = false } = Astro.props;

// Alternate language URL: toggle /en prefix keeping the same path
const currentPath = Astro.url.pathname;
const altLangUrl = lang === 'en'
  ? (currentPath.replace(/^\/en/, '') || '/')
  : ('/en' + currentPath);

const navLinks = [
  { key: 'nav.home',      href: lang === 'en' ? '/en/' : '/',             id: 'home'      },
  { key: 'nav.speakers',  href: lang === 'en' ? '/en/ponentes/' : '/ponentes/', id: 'speakers'  },
  { key: 'nav.agenda',    href: lang === 'en' ? '/en/agenda/'   : '/agenda/',   id: 'agenda'    },
  { key: 'nav.manifesto', href: lang === 'en' ? '/en/manifesto/': '/manifesto/',id: 'manifesto' },
  { key: 'nav.contact',   href: lang === 'en' ? '/en/contacto/' : '/contacto/', id: 'contact'   },
] as const;
---

<header class:list={['header', { 'header--dark': darkBg }]}>
  <!-- Logo -->
  <a href={lang === 'en' ? '/en/' : '/'} class="header-logo" aria-label="Qualicer">
    <img src="/img/logo.svg" alt="Qualicer" width="182" height="29" />
  </a>

  <!-- Nav group (desktop) -->
  <nav class="header-nav" aria-label="Navegación principal">

    <!-- Links + botón Entradas (gap 32px, igual que Figma Frame 43) -->
    <div class="header-nav-links">
      {navLinks.map(({ key, href, id }) => (
        <a href={href} class:list={['btn-nav', { active: activePage === id }]}>
          {t(key as any)}
        </a>
      ))}
      <a href="https://tickets.qualicer2026.com" target="_blank" rel="noopener" class="btn-primary">
        {t('nav.tickets' as any)}
      </a>
    </div>

    <!-- Selector de idioma (gap 48px desde el grupo, igual que Figma Frame 796) -->
    <details class="lang-switcher">
      <summary class="btn-dropdown" aria-label="Cambiar idioma">
        {lang === 'en' ? 'EN' : 'ES'}
        <svg class="lang-arrow" width="10" height="12" viewBox="0 0 10 12" fill="none" aria-hidden="true">
          <path d="M5 12L0.669872 4.5L9.33013 4.5L5 12Z" fill="currentColor"/>
        </svg>
      </summary>
      <div class="lang-menu">
        <a href={altLangUrl} class="lang-option">
          {lang === 'en' ? 'ES' : 'EN'}
        </a>
      </div>
    </details>

  </nav>

  <!-- Hamburger (mobile only) -->
  <button class="menu-toggle" aria-label="Abrir menú" aria-expanded="false" aria-controls="mobile-menu">
    <img src="/img/burguer.svg" alt="" aria-hidden="true" width="26" height="20" />
  </button>
</header>

<!-- Mobile menu panel -->
<div class="mobile-menu" id="mobile-menu" aria-hidden="true">
  <div class="mobile-menu-inner">

    <div class="mobile-menu-upper">
      <!-- Top bar: selector idioma + cerrar -->
      <div class="mobile-menu-top">
        <details class="mobile-lang-switcher">
          <summary class="mobile-lang-selector" aria-label="Cambiar idioma">
            <span>{lang === 'en' ? 'EN' : 'ES'}</span>
            <svg class="mobile-lang-arrow" width="10" height="13" viewBox="0 0 10 13" fill="none" aria-hidden="true">
              <path d="M5 12.5L0.669872 5L9.33013 5L5 12.5Z" fill="#E3E3E3"/>
            </svg>
          </summary>
          <div class="mobile-lang-menu">
            <a href={altLangUrl} class="mobile-lang-option">
              {lang === 'en' ? 'ES' : 'EN'}
            </a>
          </div>
        </details>
        <button class="mobile-menu-close" aria-label="Cerrar menú">
          <img src="/img/close.svg" alt="" aria-hidden="true" width="24" height="24" />
        </button>
      </div>

      <!-- Nav items -->
      <nav class="mobile-menu-nav" aria-label="Navegación mobile">
        {navLinks.map(({ key, href, id }) => (
          <a href={href} class:list={['mobile-nav-link', { active: activePage === id }]}>
            {t(key as any)}
          </a>
        ))}
      </nav>
    </div>

    <!-- CTA -->
    <a href="https://tickets.qualicer2026.com" target="_blank" rel="noopener" class="mobile-menu-cta">
      {t('nav.tickets' as any)}
    </a>

  </div>
</div>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const closeBtn = menu?.querySelector<HTMLButtonElement>('.mobile-menu-close');

  function openMenu() {
    menu?.classList.add('is-open');
    toggle?.setAttribute('aria-expanded', 'true');
    menu?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu?.classList.remove('is-open');
    toggle?.setAttribute('aria-expanded', 'false');
    menu?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  menu?.querySelectorAll('a').forEach(link => link.addEventListener('click', closeMenu));

  // Hide on scroll down, show on scroll up
  const header = document.querySelector<HTMLElement>('.header');
  let lastY = window.scrollY;

  window.addEventListener('scroll', () => {
    const currentY = window.scrollY;
    if (currentY > lastY && currentY > 80) {
      header?.classList.add('header--hidden');
    } else {
      header?.classList.remove('header--hidden');
    }
    lastY = currentY;
  }, { passive: true });
</script>

<style>
  .header {
    position: fixed;
    top: 0;
    z-index: 100;
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.8rem 2.4rem;   /* 16px 48px */
    background: rgba(255, 255, 255, 0.75);
    backdrop-filter: blur(8.5px);
    -webkit-backdrop-filter: blur(8.5px);
    border-bottom: 1px solid var(--color-dark);
    transition: transform 0.3s ease;
  }

  .header--hidden {
    transform: translateY(-100%);
  }

  .header-logo img {
    width: 9.1rem;
    height: auto;
  }

  /* Grupo derecho: [links+botón] | [lang] — gap 48px */
  .header-nav {
    display: flex;
    align-items: center;
    gap: 2.4rem;   /* 48px */
  }

  /* Links + botón Entradas — gap 32px */
  .header-nav-links {
    display: flex;
    align-items: center;
    gap: 1.6rem;   /* 32px */
  }

  /* Nav links: sin borde, activo con underline inferior */
  .btn-nav {
    font-family:           var(--font);
    font-size:             1rem;
    font-weight:           500;
    line-height:           1.4em;
    color:                 var(--color-dark);
    background:            transparent;
    border:                none;
    padding:               0;
    white-space:           nowrap;
    cursor:                pointer;
    text-decoration:       none;
    text-underline-offset: 3px;
    transition:            opacity 0.15s ease;
  }

  .btn-nav.active {
    text-decoration: underline;
  }

  .btn-nav:hover { opacity: 0.7; }

  /* Botón Entradas */
  .btn-primary {
    font-family:     var(--font);
    font-size:       1rem;     /* 20px */
    font-weight:     500;
    line-height:     1;
    display:         inline-flex;
    align-items:     center;
    justify-content: center;
    padding:         0.7rem 1.1rem 0.8rem;  /* 14px 22px 16px */
    background:      var(--color-primary);
    color:           var(--color-white);
    border:          none;
    border-radius:   var(--radius-pill);
    white-space:     nowrap;
    cursor:          pointer;
    text-decoration: none;
    transition:      opacity 0.15s ease;
  }

  .btn-primary:hover { opacity: 0.85; }

  /* Language switcher */
  .lang-switcher {
    position: relative;
  }

  .lang-switcher summary {
    list-style: none;
  }

  .lang-switcher summary::-webkit-details-marker {
    display: none;
  }

  .btn-dropdown {
    font-family:  var(--font);
    font-size:    1rem;
    font-weight:  500;
    line-height:  1.4em;
    color:        var(--color-dark);
    background:   transparent;
    border:       none;
    padding:      0.3rem 0;
    display:      inline-flex;
    align-items:  center;
    gap:          0.3rem;   /* 6px */
    white-space:  nowrap;
    cursor:       pointer;
    transition:   opacity 0.15s ease;
  }

  .btn-dropdown:hover { opacity: 0.7; }

  .lang-menu {
    position:    absolute;
    top:         calc(100% + 0.3rem);
    left:        0;
    min-width:   100%;
    display:     flex;
    flex-direction: column;
    background:  rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8.5px);
    -webkit-backdrop-filter: blur(8.5px);
    border:      1px solid var(--color-dark);
    border-radius: 8px;
    overflow:    hidden;
    z-index:     10;
  }

  .lang-option {
    font-family:     var(--font);
    font-size:       1rem;
    font-weight:     500;
    line-height:     1.4em;
    padding:         0.5rem 0.8rem;
    color:           var(--color-dark);
    text-align:      center;
    white-space:     nowrap;
    text-decoration: none;
    transition:      opacity 0.15s ease;
  }

  .lang-option:hover { opacity: 0.7; }

  .lang-arrow {
    transition: transform 0.2s ease;
  }

  details[open] .lang-arrow {
    transform: rotate(180deg);
  }

  /* ── Dark-bg variant (manifesto desktop) ── */
  @media (min-width: 768px) {
    .header--dark {
      background: rgba(255, 255, 255, 0.15);
      backdrop-filter: blur(4.25px);
      -webkit-backdrop-filter: blur(4.25px);
      border-bottom-color: rgba(254, 254, 254, 0.2);
    }
    .header--dark .btn-nav,
    .header--dark .btn-dropdown { color: #FEFEFE; }
    .header--dark .btn-nav.active { text-decoration-color: #FEFEFE; }
    .header--dark .header-logo img { filter: brightness(0) invert(1); }
    .header--dark .btn-primary { background: #FEFEFE; color: #0047AF; }
    .header--dark .lang-menu {
      background: rgba(0, 71, 175, 0.95);
      border-color: rgba(254, 254, 254, 0.2);
    }
    .header--dark .lang-option { color: #FEFEFE; }
  }

  /* ── Hamburger (hidden on desktop) ── */
  .menu-toggle {
    display: none;
  }

  /* ── Mobile menu panel (hidden by default) ── */
  .mobile-menu {
    display: none;
  }

  /* ── Mobile ── */
  @media (max-width: 767px) {
    .header {
      padding: 18px 24px;
    }

    .header-logo img {
      width: 135px;
    }

    .header-nav {
      display: none;
    }

    .menu-toggle {
      display: flex;
      align-items: center;
      justify-content: center;
      background: none;
      border: none;
      color: var(--color-dark);
      cursor: pointer;
      padding: 4px;
    }

    /* ── Mobile menu panel ── */
    .mobile-menu {
      display: block;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100vh;
      height: 100dvh;
      z-index: 200;
      background: #0047AF;
      transform: translateX(100%);
      transition: transform 0.28s ease;
    }

    .mobile-menu.is-open {
      transform: translateX(0);
    }

    .mobile-menu-inner {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      height: 100%;
      padding: 24px;
    }

    .mobile-menu-upper {
      display: flex;
      flex-direction: column;
      gap: 64px;
    }

    .mobile-menu-top {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
    }

    .mobile-lang-switcher {
      position: relative;
    }

    .mobile-lang-switcher summary {
      list-style: none;
    }

    .mobile-lang-switcher summary::-webkit-details-marker {
      display: none;
    }

    .mobile-lang-selector {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-family: var(--font);
      font-size: 22px;
      font-weight: 400;
      line-height: 1.4;
      color: #FEFEFE;
      cursor: pointer;
    }

    .mobile-lang-arrow {
      transition: transform 0.2s ease;
    }

    .mobile-lang-switcher[open] .mobile-lang-arrow {
      transform: rotate(180deg);
    }

    .mobile-lang-menu {
      position: absolute;
      top: 100%;
      left: 0;
    }

    .mobile-lang-option {
      display: block;
      font-family: var(--font);
      font-size: 22px;
      font-weight: 400;
      line-height: 1.4;
      padding-top: 6px;
      color: #FEFEFE;
      text-decoration: none;
      white-space: nowrap;
    }

    .mobile-lang-option:hover {
      opacity: 0.7;
    }

    .mobile-menu-close {
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .mobile-menu-close img {
      filter: invert(1);
    }

    .mobile-menu-nav {
      display: flex;
      flex-direction: column;
      gap: 36px;
    }

    .mobile-nav-link {
      font-family: var(--font);
      font-size: 40px;
      font-weight: 600;
      line-height: 1.1;
      letter-spacing: -0.02em;
      color: #FEFEFE;
      text-decoration: none;
      display: block;
    }

    .mobile-nav-link.active {
      opacity: 0.6;
    }

    .mobile-menu-cta {
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font);
      font-size: 20px;
      font-weight: 500;
      line-height: 1;
      padding: 14px 22px 16px;
      background: #FEFEFE;
      color: #0047AF;
      border-radius: 100px;
      text-decoration: none;
      transition: opacity 0.15s ease;
    }

    .mobile-menu-cta:hover {
      opacity: 0.85;
    }
  }
</style>
