---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const sponsors = [
  { file: 'equipe',    alt: 'Equipe' },
  { file: 'grespania', alt: 'Grespania Ceramica' },
  { file: 'iberdrola', alt: 'Iberdrola' },
  { file: 'italcer',   alt: 'Equipe ItalCer' },
  { file: 'kale',      alt: 'Kale Seramik' },
  { file: 'kerajet',   alt: 'KERAjet' },
  { file: 'sicer',     alt: 'Sicer' },
  { file: 'alcora',    alt: "L'Alcora Ajuntament" },
  { file: 'systemfoc', alt: 'SystemFoc' },
  { file: 'schluter',  alt: 'Schlüter Systems' },
];
---

<section class="b4">
  <div class="b4-header">
    <h2 class="b4-title">{t('b4.title' as any)}</h2>
  </div>
  <div class="b4-logos" id="b4-logos">
    {sponsors.map(s => (
      <img src={`/img/sponsors/${s.file}.svg`} alt={s.alt} class="b4-logo" draggable="false" />
    ))}
  </div>
</section>

<script>
  const logos = document.getElementById('b4-logos') as HTMLElement;
  if (logos) {
    const rootFs  = parseFloat(getComputedStyle(document.documentElement).fontSize);
    const padLeft = parseFloat(getComputedStyle(logos).paddingLeft);

    const isMobile  = window.innerWidth <= 767;
    const isWide    = window.innerWidth > 1920;
    const init = () => {
      if (isWide) return;
      logos.scrollLeft = isMobile ? 60 : padLeft + 3 * rootFs;
    };
    // esperar a que los SVG tengan dimensiones
    if (document.readyState === 'complete') init();
    else window.addEventListener('load', init);

    let dragging = false, startX = 0, startScroll = 0;

    logos.addEventListener('mousedown', (e) => {
      dragging    = true;
      startX      = e.clientX;
      startScroll = logos.scrollLeft;
      logos.style.cursor = 'grabbing';
      e.preventDefault();
    });

    window.addEventListener('mouseup', () => {
      dragging = false;
      logos.style.cursor = 'grab';
    });

    window.addEventListener('mousemove', (e) => {
      if (!dragging) return;
      logos.scrollLeft = startScroll - (e.clientX - startX);
    });
  }
</script>

<style>
  /* ── Desktop ──────────────────────────────────────────── */
  .b4 {
    width: 100%;
    margin-top: 9.8rem;
  }

  .b4-header {
    max-width: 1920px;
    margin-left: auto;
    margin-right: auto;
    padding: 0 2.4rem;
  }

  .b4-title {
    font-size: 1.5rem;          /* 30px — DESKTOP H1 */
    font-weight: 600;
    line-height: 1.1em;
    color: var(--color-dark);
    height: 3.5rem;             /* 70px */
    display: flex;
    align-items: center;
  }

  .b4-logos {
    display: flex;
    align-items: center;
    gap: 6.1rem;
    padding: 1.6rem 2.4rem;
    overflow-x: auto;
    scrollbar-width: none;
    cursor: grab;
    user-select: none;
  }

  .b4-logos::-webkit-scrollbar {
    display: none;
  }

  @media (min-width: 1921px) {
    .b4-logos {
      justify-content: center;
    }
  }

  .b4-logo {
    flex-shrink: 0;
    display: block;
    height: auto;
    pointer-events: none;
  }

  /* ── Mobile ───────────────────────────────────────────── */
  @media (max-width: 767px) {
    .b4 {
      margin-top: 196px;
    }

    .b4-header {
      padding: 0 16px;
    }

    .b4-title {
      font-size: 20px !important;
      height: auto;
      margin-bottom: 24px;
    }

    .b4-logos {
      gap: 48px;
      padding: 16px 16px;
      cursor: default;
      overscroll-behavior-x: contain;
    }
  }
</style>
