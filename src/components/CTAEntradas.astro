---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t    = useTranslations(lang);

const entradasHref = 'https://tickets.qualicer2026.com';
---

<section class="b8">
  <div class="b8-card">

    <!-- Vídeo desktop: lado izquierdo, 911×597px -->
    <video class="b8-vid-d" autoplay muted loop playsinline preload="metadata" aria-hidden="true">
      <source src="/videos/banner.mp4" type="video/mp4" />
    </video>

    <div class="b8-right">
      <!-- Vídeo mobile: encima del contenido, oculto en desktop -->
      <video class="b8-vid-m" autoplay muted loop playsinline preload="metadata" aria-hidden="true">
        <source src="/videos/banner.mp4" type="video/mp4" />
      </video>

      <div class="b8-body">
        <div class="b8-meta">
          <span class="b8-meta-item">{t('b8.date')}</span>
          <div class="b8-venues">
            <span class="b8-meta-item">{t('b8.venue')}</span>
            <span class="b8-meta-item">{t('b8.city')}</span>
          </div>
        </div>
        <h2 class="b8-title">{t('b8.headline')}</h2>
        <a href={entradasHref} target="_blank" rel="noopener" class="b8-btn">{t('b8.cta')}</a>
      </div>
    </div>

  </div>
</section>

<style>
  /* ─── Desktop ───────────────────────────────────────────── */
  .b8 {
    max-width:  1920px;
    margin:     9.8rem auto 0;
    padding:    0 2.4rem;
  }

  .b8-card {
    display:       flex;
    flex-direction: row;
    align-items:   flex-end;
    gap:           1.6rem;      /* 32px */
    border-radius: 30px;
    background:    #FFFFFF;
    overflow:      hidden;
  }

  /* Vídeo desktop */
  .b8-vid-d {
    width:       45.55rem;   /* 911px */
    height:      29.85rem;   /* 597px */
    object-fit:  cover;
    flex-shrink: 0;
    display:     block;
  }

  .b8-vid-m { display: none; }

  /* Columna derecha: ocupa el espacio restante */
  .b8-right {
    flex:           1;
    display:        flex;
    flex-direction: column;
    align-self:     stretch;
  }

  /* Body: columna — meta arriba, título al medio, botón abajo */
  .b8-body {
    flex:            1;
    display:         flex;
    flex-direction:  column;
    justify-content: space-between;
    padding:         1.6rem 1.6rem 1.6rem 0; /* top right bottom left=0 */
  }

  /* Fila de metadatos: fecha | venue + ciudad */
  .b8-meta {
    display:        flex;
    flex-direction: row;
    align-items:    flex-start;
    gap:            3.2rem;    /* 64px */
  }

  .b8-venues {
    display: flex;
    gap:     1rem;             /* 20px */
  }

  .b8-meta-item {
    font-size:   0.8rem;       /* 16px */
    font-weight: 400;
    line-height: 1.2em;
    color:       var(--color-dark);
    white-space: pre-line;     /* respeta los \n de los textos */
  }

  /* Titular */
  .b8-title {
    width:          26.55rem;  /* 531px */
    font-size:      2.4rem;    /* 48px */
    font-weight:    600;
    line-height:    1.1em;
    letter-spacing: -0.02em;
    color:          var(--color-dark);
  }

  /* Botón primario — anclado abajo-derecha */
  .b8-btn {
    align-self:      flex-end;
    display:         inline-flex;
    justify-content: center;
    align-items:     center;
    padding:         0.7rem 1.1rem 0.8rem;
    background:      var(--color-primary);
    color:           var(--color-white);
    border:          none;
    border-radius:   100px;
    font-family:     inherit;
    font-size:       1rem;     /* 20px */
    font-weight:     500;
    line-height:     1;
    text-decoration: none;
    white-space:     nowrap;
    cursor:          pointer;
  }

  /* ─── Mobile ────────────────────────────────────────────── */
  @media (max-width: 767px) {
    .b8 {
      margin-top: 196px;
      padding:    0 16px;
    }

    .b8-card {
      flex-direction: column;
      align-items:    stretch;
      gap:            0;
    }

    /* Vídeo desktop oculto; vídeo mobile visible */
    .b8-vid-d { display: none; }

    .b8-vid-m {
      display:    block;
      width:      100%;
      height:     235px;
      object-fit: cover;
    }

    .b8-right { flex: unset; }

    /* Body pasa a columna con gap 64px */
    .b8-body {
      flex-direction: column;
      align-items:    stretch;
      justify-content: flex-start;
      padding:        32px 16px 16px;
      gap:            64px;
    }

    /* Meta: fecha izquierda, venue+ciudad agrupados derecha */
    .b8-meta {
      justify-content: space-between;
      align-items:     flex-start;
      gap:             0;
    }

    .b8-venues {
      flex-direction: row;
      gap:            20px;
    }

    .b8-meta-item {
      font-size:   12px;
      white-space: pre-line;
    }

    /* Botón full-width en mobile — anula align-self:flex-end del desktop */
    .b8-btn { align-self: stretch; }

    /* Titular mobile */
    .b8-title {
      width:          auto;
      font-size:      48px;
      letter-spacing: -0.04em;
      line-height:    1em;
    }

    /* Botón full-width */
    .b8-btn {
      display:    flex;
      width:      100%;
      box-sizing: border-box;
      font-size:  16px;
      padding:    14px 22px 16px;
    }
  }
</style>
