---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const cards = [
  {
    gif:      'calidad',
    gradient: 'linear-gradient(0deg, rgba(0, 71, 175, 0.00) 0%, #0047AF 139.17%)',
    title:    t('b5.card1.title' as any),
    desc:     t('b5.card1.desc'  as any),
  },
  {
    gif:      'futuro',
    gradient: 'linear-gradient(0deg, rgba(233, 0, 43, 0.00) 0%, #E9002B 139.17%)',
    title:    t('b5.card2.title' as any),
    desc:     t('b5.card2.desc'  as any),
  },
  {
    gif:      'estrategia',
    gradient: 'linear-gradient(0deg, rgba(54, 163, 223, 0.00) 0%, #36A3DF 139.17%)',
    title:    t('b5.card3.title' as any),
    desc:     t('b5.card3.desc'  as any),
  },
  {
    gif:      'sostenibilidad',
    gradient: 'linear-gradient(0deg, rgba(111, 197, 183, 0.00) 0%, #6FC5B7 139.17%)',
    title:    t('b5.card4.title' as any),
    desc:     t('b5.card4.desc'  as any),
  },
  {
    gif:      'innovacion',
    gradient: 'linear-gradient(0deg, rgba(242, 137, 167, 0.00) 0%, #F289A7 139.17%)',
    title:    t('b5.card5.title' as any),
    desc:     t('b5.card5.desc'  as any),
  },
];
---

<section class="b5">
  <h2 class="b5-title">{t('b5.title' as any)}</h2>
  <div class="b5-cards">
    {cards.map(card => (
      <div class="b5-card" style={`--grad: ${card.gradient}`}>
        <div class="b5-overlay"></div>
        <img class="b5-gif" src={`/img/${card.gif}.gif`} alt="" />
        <div class="b5-text">
          <p class="b5-card-title">{card.title}</p>
          <p class="b5-desc">{card.desc}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  /* ── Desktop ──────────────────────────────────────────── */
  .b5 {
    max-width: 1920px;
    margin-left: auto;
    margin-right: auto;
    margin-top: 9.8rem;
    padding: 0 2.4rem;
  }

  .b5-title {
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.1em;
    color: var(--color-dark);
    margin-bottom: 1.8rem;
  }

  .b5-cards {
    display: flex;
    gap: 0.8rem;
  }

  .b5-card {
    position: relative;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2.4rem;
    padding: 1.6rem;
    border-radius: var(--radius-card);
    background: var(--color-white);
    overflow: hidden;
  }

  .b5-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 12rem;
    background: var(--grad);
    pointer-events: none;
    z-index: 1;
  }

  .b5-gif {
    width: 100%;
    height: 8.15rem;
    object-fit: cover;
    display: block;
  }

  .b5-text {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
    position: relative;
    z-index: 2;
  }

  .b5-card-title {
    font-size: 1.1rem;
    font-weight: 700;
    line-height: 1.2em;
    color: var(--color-dark);
  }

  .b5-desc {
    font-size: 0.8rem;
    font-weight: 400;
    line-height: 1.4em;
    color: var(--color-dark);
  }

  /* ── Mobile ───────────────────────────────────────────── */
  @media (max-width: 767px) {
    .b5 {
      margin-top: 196px;
      padding: 0 16px;
    }

    .b5-title {
      font-size: 21px !important;
      margin-bottom: 24px;
    }

    .b5-cards {
      flex-direction: column;
      gap: 16px;
    }

    .b5-card {
      flex: none;
      gap: 48px !important;
      padding: 32px !important;
      border-radius: 30px !important;
    }

    .b5-overlay {
      height: 240px !important;
    }

    .b5-gif {
      height: 163px !important;
    }

    .b5-card-title {
      font-size: 22px !important;
    }

    .b5-desc {
      font-size: 14px !important;
    }
  }
</style>
