---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

function lines(str: string) {
  return str.split('\n');
}
---

<section class="b3">
  <div class="b3-content">
    <div class="b3-brand">
      <img src="/img/logo.svg" alt="Qualicer" class="b3-logo" />
      <p class="b3-tagline">Now, the full view</p>
    </div>
    <h2 class="b3-headline">
      {lines(t('b3.headline' as any)).map((l, i, arr) => (
        <>{l}{i < arr.length - 1 && <br />}</>
      ))}
    </h2>
  </div>
</section>

<style>
  /* ── Desktop ──────────────────────────────────────────── */
  .b3 {
    position: relative;
    width: 100%;
    max-width: 1920px;
    margin-top: 9.8rem;       /* 196px — mismo gap que site-sections */
    margin-left: auto;
    margin-right: auto;
    height: 29.9rem;          /* 598px */
    overflow: hidden;
    display: flex;
    justify-content: center;
  }

  .b3::before {
    content: '';
    position: absolute;
    width: 100%;
    height: 45.05rem;         /* 901px */
    top: -10.9rem;            /* -218px */
    left: 0;
    background: radial-gradient(
      circle at 50% 56%,
      rgba(0, 71, 175, 0.5) 0%,
      rgba(0, 71, 175, 0) 100%
    );
    z-index: 0;
    pointer-events: none;
  }

  .b3-content {
    position: relative;
    z-index: 1;
    width: 61.8rem;           /* 1236px */
    padding-top: 3rem;        /* 60px */
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5rem;                /* 100px */
  }

  .b3-brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.6rem;              /* 32px */
  }

  .b3-logo {
    width: 9.1rem;            /* 182px */
    height: auto;
  }

  .b3-tagline {
    font-size: 2.4rem;        /* 48px — DESKTOP Display M */
    font-weight: 600;
    line-height: 1.1em;
    letter-spacing: -0.02em;
    color: var(--color-dark);
    text-align: center;
  }

  .b3-headline {
    font-size: 6.5rem;        /* 130px — DESKTOP Display L */
    font-weight: 600;
    line-height: 1em;
    letter-spacing: -0.04em;
    color: var(--color-dark);
    text-align: center;
  }

  /* ── Mobile ───────────────────────────────────────────── */
  @media (max-width: 767px) {
    .b3 {
      height: auto;
      padding: 48px 0;
      margin-top: 196px;
    }

    .b3::before {
      width: 574px;
      height: 639px;
      top: -150px;
      left: -92px;
      background: radial-gradient(
        circle at 50% 51%,
        rgba(0, 71, 175, 0.5) 0%,
        rgba(0, 71, 175, 0.315) 36%,
        rgba(0, 71, 175, 0) 100%
      );
    }

    .b3-content {
      width: 100%;
      padding: 0 20px;
      gap: 64px;
    }

    .b3-logo {
      width: 134px;
    }

    .b3-tagline {
      font-size: 32px !important;
    }

    .b3-headline {
      font-size: 48px !important;
      line-height: 1em;
    }
  }
</style>
