---
import '../styles/global.css';

interface Props {
  title?: string;
  lang?: string;
  description?: string;
}

const {
  title = 'Qualicer — XIX Congreso Mundial de Calidad Cerámica',
  lang = 'es',
  description = 'El foro internacional donde innovación cerámica, calidad y transformación se entienden en todas sus dimensiones.',
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/img/logo.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
