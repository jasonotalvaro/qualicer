---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import DatosForum from '../components/DatosForum.astro';
import BrandQuote from '../components/BrandQuote.astro';
import Sponsors from '../components/Sponsors.astro';
import EjesTransversales from '../components/EjesTransversales.astro';
import PonentesDestacados from '../components/PonentesDestacados.astro';
import AgendaTematicas from '../components/AgendaTematicas.astro';
import CTAEntradas from '../components/CTAEntradas.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  lang="es"
  title="Qualicer — XIX Congreso Mundial de Calidad Cerámica"
  description="El foro internacional donde innovación cerámica, calidad y transformación se entienden en todas sus dimensiones."
>
  <Header activePage="home" />
  <main>
    <Hero />
    <div class="site-sections">
      <DatosForum />
    </div>
    <BrandQuote />
    <Sponsors />
    <EjesTransversales />
    <PonentesDestacados />
    <AgendaTematicas />
    <CTAEntradas />
    <Footer />
  </main>
</Layout>
